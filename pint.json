{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "final_class": false,
        "ordered_class_elements": {
            "order": [
                "use_trait",
                "case",
                "constant",
                "property",
                "construct",
                "destruct",
                "magic",
                "phpunit",
                "method"
            ]
        },
        "global_namespace_import": {
            "import_classes": true,
            "import_constants": true,
            "import_functions": true
        }
    }
}
